    "    print('⚠️  REPO_URL khaali hai. Neeche wale cell se manual setup chalega.')\n",
    "\n",
    "# Required folders banao\n",
    "os.makedirs('models', exist_ok=True)\n",
    "os.makedirs('temp', exist_ok=True)\n",
    "os.makedirs('output', exist_ok=True)\n",
    "print('✅ Directories ready')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Cell 4 — Real-ESRGAN repo + models download karo\n",
    "*(Pehli baar ~130 MB download hoga, dobara nahi hoga)*"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import os, requests\n",
    "\n",
    "MODELS_DIR = 'models'\n",
    "REPO_DIR   = 'Real-ESRGAN'\n",
    "\n",
    "# 1. Official repo clone\n",
    "if not os.path.exists(REPO_DIR):\n",
    "    print('Cloning Real-ESRGAN v0.3.0...')\n",
    "    !git clone --depth 1 --branch v0.3.0 https://github.com/xinntao/Real-ESRGAN.git {REPO_DIR}\n",
    "else:\n",
    "    print('✅ Real-ESRGAN repo already exists')\n",
    "\n",
    "# 2. Model weights download\n",
    "MODELS = {\n",
    "    'RealESRGAN_x4plus.pth': 'https://github.com/xinntao/Real-ESRGAN/releases/download/v0.1.0/RealESRGAN_x4plus.pth',\n",
    "    'RealESRGAN_x2plus.pth': 'https://github.com/xinntao/Real-ESRGAN/releases/download/v0.2.1/RealESRGAN_x2plus.pth',\n",
    "}\n",
    "\n",
    "for fname, url in MODELS.items():\n",
    "    dest = os.path.join(MODELS_DIR, fname)\n",
    "    if os.path.exists(dest):\n",
    "        print(f'✅ {fname} already cached')\n",
    "        continue\n",
    "    print(f'Downloading {fname}...')\n",
    "    r = requests.get(url, stream=True)\n",
    "    with open(dest, 'wb') as f:\n",
    "        for chunk in r.iter_content(65536):\n",
    "            f.write(chunk)\n",
    "    print(f'✅ {fname} downloaded')\n",
    "\n",
    "print('\\n🎉 Models ready!')"
   ]
  },
