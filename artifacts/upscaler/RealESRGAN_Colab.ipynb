   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Cell 6 — Server start karo aur public URL lo"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import subprocess, time, threading\n",
    "from pyngrok import ngrok\n",
    "\n",
    "PORT = 8000\n",
    "\n",
    "# FastAPI server background mein start karo\n",
    "server = subprocess.Popen(\n",
    "    ['python', 'main.py'],\n",
    "    stdout=subprocess.PIPE,\n",
    "    stderr=subprocess.STDOUT,\n",
    ")\n",
    "\n",
    "# Server ready hone ka wait karo\n",
    "print('Server start ho raha hai...')\n",
    "time.sleep(15)  # Models load hone mein time lagta hai\n",
    "\n",
    "# ngrok tunnel kholo\n",
    "tunnel = ngrok.connect(PORT)\n",
    "PUBLIC_URL = tunnel.public_url\n",
    "\n",
    "print('\\n' + '='*60)\n",
    "print(f'🌐 Public API URL:  {PUBLIC_URL}')\n",
    "print(f'📖 Swagger Docs:   {PUBLIC_URL}/docs')\n",
    "print(f'📘 ReDoc:          {PUBLIC_URL}/redoc')\n",
    "print('='*60)\n",
    "\n",
    "# API key generate karo\n",
    "import requests as req\n",
    "r = req.post(f'http://localhost:{PORT}/api/v1/generate-api-key?name=colab-key')\n",
    "key_data = r.json()\n",
    "print(f\"\\n🔑 Aapki API Key: {key_data['api_key']}\")\n",
    "print(\"Ise save karo! Har request mein X-API-Key header mein bhejo.\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Cell 7 — Test: Image upscale karo"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import requests\n",
    "from IPython.display import Image as IPImage, display\n",
    "from PIL import Image\n",
    "import io\n",
    "\n",
    "# Yahan apni API key dalo (upar wale cell se)\n",
    "API_KEY = key_data['api_key']  # ya manually: \"resr_...\"\n",
    "BASE    = f'http://localhost:{PORT}'\n",
    "\n",
    "# Test image banao (ya apni image ka path dalo)\n",
    "test_img = Image.new('RGB', (100, 100), color=(30, 80, 160))\n",
    "buf = io.BytesIO()\n",
    "test_img.save(buf, format='PNG')\n",
    "buf.seek(0)\n",
    "\n",
    "# Upload & upscale\n",
    "resp = requests.post(\n",
    "    f'{BASE}/api/v1/upscale-image',\n",
    "    headers={'X-API-Key': API_KEY},\n",
    "    files={'file': ('test.png', buf, 'image/png')},\n",
    "    data={'scale': '4', 'output_format': 'PNG', 'compression': 'balanced'},\n",
    ")\n",
    "job = resp.json()\n",
    "print('Job:', job)\n",
    "\n",
    "# Status poll karo\n",
    "import time\n",
    "for _ in range(30):\n",
    "    time.sleep(3)\n",
    "    s = requests.get(f\"{BASE}/api/v1/status/{job['job_id']}\", headers={'X-API-Key': API_KEY}).json()\n",
    "    print(f\"Status: {s['status']}\")\n",
    "    if s['status'] in ('completed', 'failed'):\n",
    "        break\n",
    "\n",
    "# Download & display\n",
    "if s['status'] == 'completed':\n",
    "    dl = requests.get(f\"{BASE}/api/v1/download/{job['job_id']}\", headers={'X-API-Key': API_KEY})\n",
    "    result = Image.open(io.BytesIO(dl.content))\n",
    "    print(f'\\n✅ Upscaled size: {result.size}')\n",
    "    display(result)\n",
    "else:\n",
    "    print('❌ Failed:', s.get('error'))"
   ]
  },
